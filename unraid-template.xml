<?xml version="1.0"?>
<Container version="2">
  <Name>stros-objednavky</Name>
  <Repository>ghcr.io/vituhlos/stros-objednavky:latest</Repository>
  <Registry>https://ghcr.io/vituhlos/stros-objednavky</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Overview>Interní objednávkový systém STROS pro správu objednávek obědů (LIMA) a pizzy. Bez přihlášení, sdílený objednávkový list po odděleních, odeslání e-mailem s PDF přílohou.</Overview>
  <Category>Productivity: Tools:</Category>
  <WebUI>http://[IP]:[PORT:3000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/vituhlos/stros-objednavky/main/unraid-template.xml</TemplateURL>
  <ExtraParams>--restart=unless-stopped</ExtraParams>
  <Description>Interní objednávkový systém STROS. Správa objednávek obědů (LIMA) a pizzy, import jídelníčku z PDF, odesílání e-mailem s PDF přílohou. Běží jako jeden kontejner bez externích závislostí.</Description>
  <Project>https://github.com/vituhlos/stros-objednavky</Project>

  <Config
    Name="WebUI Port"
    Target="3000"
    Default="3000"
    Mode="tcp"
    Description="Port pro webové rozhraní aplikace."
    Type="Port"
    Display="always"
    Required="true"
    Mask="false">3000</Config>

  <Config
    Name="Data"
    Target="/app/data"
    Default="/mnt/user/appdata/stros-objednavky"
    Mode="rw"
    Description="Adresář pro SQLite databázi. Musí být namapován pro persistenci dat."
    Type="Path"
    Display="always"
    Required="true"
    Mask="false">/mnt/user/appdata/stros-objednavky</Config>

  <Config
    Name="SMTP Host"
    Target="SMTP_HOST"
    Default=""
    Mode=""
    Description="Adresa SMTP serveru, např. smtp.gmail.com"
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false"></Config>

  <Config
    Name="SMTP Port"
    Target="SMTP_PORT"
    Default="587"
    Mode=""
    Description="Port SMTP serveru. Obvykle 587 (STARTTLS) nebo 465 (SSL)."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false">587</Config>

  <Config
    Name="SMTP User"
    Target="SMTP_USER"
    Default=""
    Mode=""
    Description="Přihlašovací jméno (e-mailová adresa) pro SMTP."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false"></Config>

  <Config
    Name="SMTP Password"
    Target="SMTP_PASS"
    Default=""
    Mode=""
    Description="Heslo pro SMTP účet."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="true"></Config>

  <Config
    Name="SMTP From"
    Target="SMTP_FROM"
    Default=""
    Mode=""
    Description="Odesílatel (From adresa). Pokud prázdné, použije se SMTP_USER."
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false"></Config>

  <Config
    Name="SMTP Secure (TLS)"
    Target="SMTP_SECURE"
    Default="false"
    Mode=""
    Description="Použít TLS. Nastavte true pro port 465."
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false">false</Config>

  <Config
    Name="Výchozí příjemce objednávky"
    Target="ORDER_EMAIL_TO"
    Default="jirirytir1992@gmail.com"
    Mode=""
    Description="E-mailová adresa, na kterou se odesílá objednávka."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="false">jirirytir1992@gmail.com</Config>

  <Config
    Name="PIN pro Nastavení"
    Target="SETTINGS_PIN"
    Default="1234"
    Mode=""
    Description="PIN kód pro přístup ke stránce Nastavení."
    Type="Variable"
    Display="always"
    Required="false"
    Mask="true">1234</Config>

</Container>
